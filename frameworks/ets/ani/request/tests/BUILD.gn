import("//base/request/request/request_aafwk.gni")
import("//build/test.gni")

ohos_rust_unittest("request_ani_ut_test") {
  module_out_path = "request/request/request_ani"

  sources = [ "entry.rs" ]

  deps = [
    "../:request_ani",
    "../../../../common/utils:request_utils",
  ]

  rustflags = [ "--cfg=feature=\"oh\"" ]

  external_deps = [
    "hilog:hilog_rust",
    "ipc:ipc_rust",
    "samgr:samgr_rust",
    "ylong_runtime:ylong_runtime",
  ]

  subsystem_name = "request"
  part_name = "request"
}

group("unittest") {
  testonly = true
  deps = [ ":request_ani_ut_test" ]
}
